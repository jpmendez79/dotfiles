IMAPAccount lsu
Host 127.0.0.1
Port 1143
User jmend46@lsu.edu
# PassCmd "gpg2 -q -d ~/.authinfo.gpg | awk -F'\"' 'FNR == 4 {print $2}'"
PassCmd "pass show token/mbsync_lsu"
# Is it literally the comment?
# For whatever reason mbsync NEEDS a comment string below the above passcmd
TLSType None
Authmechs LOGIN
PipelineDepth 1

IMAPStore lsu-remote
Account lsu
MaxSize 40M
PathDelimiter /

MaildirStore lsu-local
# AltMap yes
Subfolders Verbatim
Path ~/.mail/lsu/
Inbox ~/.mail/lsu/Inbox

Channel lsu
Far :lsu-remote:
Near :lsu-local:
SyncState *
Patterns *
Create Both
Expunge Both
Sync All
